<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{companyName}} - Asset Marked as Lost</title>
    <style>
      body { margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 15px; line-height: 1.6; color: #2d3748; background: #f7fafc; }
      .wrapper { padding: 40px 20px; }
      .container { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.07); }
      .header { background: linear-gradient(135deg, #c53030 0%, #9b2c2c 100%); padding: 32px 40px; text-align: center; color: #fff; }
      .header h1 { margin: 0; font-size: 22px; font-weight: 600; }
      .content { padding: 32px 40px; }
      .greeting { font-size: 16px; color: #1a365d; margin-bottom: 20px; }
      .alert-box { background: #fff5f5; border-left: 4px solid #c53030; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
      .info-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
      .info-table td { padding: 12px 16px; border-bottom: 1px solid #e2e8f0; }
      .info-table td:first-child { font-weight: 600; color: #4a5568; width: 40%; }
      .info-table tr:last-child td { border-bottom: none; }
      .recovery-box { background: #fffaf0; border: 1px solid #f6ad55; padding: 16px 20px; border-radius: 6px; margin: 20px 0; }
      .recovery-box .amount { font-size: 24px; font-weight: 700; color: #c05621; }
      .footer { background: #edf2f7; padding: 20px 40px; text-align: center; color: #718096; font-size: 12px; }
      .footer a { color: #2c5282; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <h1>🚨 Asset Marked as Lost</h1>
        </div>
        <div class="content">
          <p class="greeting">Hi <strong>{{employeeName}}</strong>,</p>
          <div class="alert-box">
            <strong>{{actorName}}</strong> has marked the asset previously assigned to you as <strong>LOST</strong>.
          </div>
          <table class="info-table">
            <tr><td>Asset</td><td>{{assetName}}{{#if serialNumber}} (SN: {{serialNumber}}){{/if}}</td></tr>
            <tr><td>Asset ID</td><td>{{assetId}}</td></tr>
            <tr><td>Reason</td><td>{{reason}}</td></tr>
            <tr><td>Last seen</td><td>{{lastSeenDate}} at {{lastSeenLocation}}</td></tr>
            <tr><td>Marked by</td><td>{{actorName}}</td></tr>
            <tr><td>Marked on</td><td>{{markedOn}}</td></tr>
          </table>
          {{#if recoveryAmount}}
            <div class="recovery-box">
              <div style="font-size: 13px; color: #744210; margin-bottom: 6px;">RECOVERY AMOUNT CHARGED</div>
              <div class="amount">₹{{recoveryAmount}}</div>
              <div style="font-size: 13px; color: #744210; margin-top: 8px;">This has been added as a debit to your expense account. Please contact HR for any concerns.</div>
            </div>
          {{/if}}
          <p style="color: #4a5568; margin-top: 24px;">If you believe this is an error or have any information about the asset, please reach out to your Asset Manager or HR immediately.</p>
        </div>
        <div class="footer">
          <p>This is an automated notification from <strong>{{companyName}}</strong>.<br />Year {{currentYear}}.</p>
        </div>
      </div>
    </div>
  </body>
</html>
