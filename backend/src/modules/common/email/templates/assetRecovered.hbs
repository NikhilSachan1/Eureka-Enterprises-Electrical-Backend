<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{companyName}} - Asset Recovered</title>
    <style>
      body { margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, sans-serif; font-size: 15px; line-height: 1.6; color: #2d3748; background: #f7fafc; }
      .wrapper { padding: 40px 20px; }
      .container { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.07); }
      .header { background: linear-gradient(135deg, #2f855a 0%, #276749 100%); padding: 32px 40px; text-align: center; color: #fff; }
      .header h1 { margin: 0; font-size: 22px; font-weight: 600; }
      .content { padding: 32px 40px; }
      .greeting { font-size: 16px; color: #1a365d; margin-bottom: 20px; }
      .success-box { background: #f0fff4; border-left: 4px solid #2f855a; padding: 16px 20px; border-radius: 4px; margin: 20px 0; }
      .info-table { width: 100%; border-collapse: collapse; margin: 20px 0; }
      .info-table td { padding: 12px 16px; border-bottom: 1px solid #e2e8f0; }
      .info-table td:first-child { font-weight: 600; color: #4a5568; width: 40%; }
      .info-table tr:last-child td { border-bottom: none; }
      .refund-box { background: #f0fff4; border: 1px solid #48bb78; padding: 16px 20px; border-radius: 6px; margin: 20px 0; }
      .refund-box .amount { font-size: 24px; font-weight: 700; color: #2f855a; }
      .footer { background: #edf2f7; padding: 20px 40px; text-align: center; color: #718096; font-size: 12px; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <h1>✅ Asset Recovered</h1>
        </div>
        <div class="content">
          <p class="greeting">Hi <strong>{{employeeName}}</strong>,</p>
          <div class="success-box">
            Good news — the previously lost asset has been <strong>recovered</strong> by <strong>{{actorName}}</strong>.
          </div>
          <table class="info-table">
            <tr><td>Asset</td><td>{{assetName}}{{#if serialNumber}} (SN: {{serialNumber}}){{/if}}</td></tr>
            <tr><td>Asset ID</td><td>{{assetId}}</td></tr>
            {{#if notes}}<tr><td>Notes</td><td>{{notes}}</td></tr>{{/if}}
            <tr><td>Recovered by</td><td>{{actorName}}</td></tr>
            <tr><td>Recovered on</td><td>{{recoveredOn}}</td></tr>
          </table>
          {{#if refundedAmount}}
            <div class="refund-box">
              <div style="font-size: 13px; color: #22543d; margin-bottom: 6px;">REFUND ISSUED</div>
              <div class="amount">₹{{refundedAmount}}</div>
              <div style="font-size: 13px; color: #22543d; margin-top: 8px;">This amount has been credited back to your expense account.</div>
            </div>
          {{/if}}
        </div>
        <div class="footer">
          <p>This is an automated notification from <strong>{{companyName}}</strong>.<br />Year {{currentYear}}.</p>
        </div>
      </div>
    </div>
  </body>
</html>
